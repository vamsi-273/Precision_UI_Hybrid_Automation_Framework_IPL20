<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="IPL Suite for Chrome">

    <listeners>
        <listener class-name="com.ipl.automation.utils.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="IPL Tests for Chrome">
        <classes>
            <class name ="tests.FooterLinksTest"/>
            <class name ="tests.TeamsTest"/>
            <class name ="tests.PointsTableTest"/>
            <class name ="tests.SearchTest"/>
            <class name ="tests.TicketsTest"/>
            <class name ="tests.VenuesTest"/>
            <class name ="tests.AuctionTest"/>
            <class name ="tests.StatsTest"/>
        </classes>
    </test>
</suite>